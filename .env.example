# TeamSpeak ServerQuery
TS3_HOST=127.0.0.1
TS3_PORT=10011
TS3_USER=serveradmin
TS3_PASSWORD=your_password
TS3_VSERVER_ID=1

# Matrix (required; MATRIX_ROOM_ID accepts !room:server or #alias:server)
MATRIX_HOMESERVER=https://matrix.example.com
MATRIX_USER_ID=@bot:example.com
MATRIX_ACCESS_TOKEN=your_access_token
MATRIX_ROOM_ID=!roomid:example.com

# Optional
BOT_MESSAGES_FILE=bot_messages.json
WATCHDOG_TIMEOUT=1800

# Optional storage overrides
# MATRIX_SESSION_DIR=
# MATRIX_SESSION_FILE=
# TSMATRIX_DATA_DIR=

# Optional health endpoints
# HEALTHCHECK_HOST=0.0.0.0
# HEALTHCHECK_PORT=8080
# HEALTHCHECK_PATH_LIVE=/healthz/live
# HEALTHCHECK_PATH_READY=/healthz/ready
